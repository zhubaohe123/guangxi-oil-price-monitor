# OpenAI兼容API配置
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 数据库配置
DATABASE_URL=sqlite:///data/oil_prices.db
# 或使用PostgreSQL
# DATABASE_URL=postgresql://oilmonitor:password@localhost:5432/oil_prices

# Redis配置
REDIS_URL=redis://localhost:6379/0

# 应用配置
DEBUG=false
LOG_LEVEL=INFO

# 数据收集配置
COLLECTION_SCHEDULE=0 8 * * *  # 每天8点收集
ANALYSIS_SCHEDULE=0 9 * * *    # 每天9点分析

# 飞书通知配置（可选）
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_BOT_WEBHOOK=your_webhook_url

# 邮件通知配置（可选）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_password
NOTIFICATION_EMAIL=recipient@example.com